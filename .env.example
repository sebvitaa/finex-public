# FinEx local development
FINEX_ENV=development
FINEX_APP_NAME=FinEx
FINEX_DATABASE_URL=sqlite:///./data/local/finex.db
FINEX_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local API defaults
FINEX_API_HOST=127.0.0.1
FINEX_API_PORT=8000

# Frontend. Leave empty in Vite dev to use the local proxy.
VITE_FINEX_API_URL=
# Optional public links shown in the landing page.
VITE_FINEX_GITHUB_URL=https://github.com/tu-usuario/finex

# Gmail API OAuth.
# Store both files under data/local/ so secrets and tokens stay ignored by git.
GMAIL_CREDENTIALS_PATH=data/local/gmail_credentials.json
GMAIL_TOKEN_PATH=data/local/gmail_token.json
GMAIL_REDIRECT_URI=http://127.0.0.1:8000/api/v1/gmail/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
GMAIL_DEFAULT_QUERY=newer_than:30d

# Optional AI configuration. Keep disabled unless explicitly needed.
AI_PROVIDER=none
AI_MODEL=
